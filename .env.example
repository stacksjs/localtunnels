# Porkbun DNS API credentials (used by `deploy:site` / src/cloud/deploy-site.ts).
# Create an API key pair at https://porkbun.com/account/api and enable API
# access on the relevant domain. Never commit the real values — keep them in
# an untracked `.env` (already in .gitignore).
PORKBUN_API_KEY=your-porkbun-api-key
PORKBUN_SECRET_KEY=your-porkbun-secret-key
